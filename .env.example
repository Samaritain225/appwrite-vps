# Appwrite VPS Deployment Configuration
# Copy this file to .env and fill in your values

# Deployment
_APP_ENV=production
_APP_DOMAIN=appwrite.yourdomain.com
_APP_DOMAIN_SITES=*.appwrite.yourdomain.com
_APP_DOMAIN_FUNCTIONS=*.functions.appwrite.yourdomain.com

# Database (MariaDB)
_APP_DB_HOST=mariadb
_APP_DB_ADAPTER=mariadb
_APP_DB_PORT=3306
_APP_DB_SCHEMA=appwrite
_APP_DB_USER=appwrite
_APP_DB_PASS=change_me_db_password
_APP_DB_ROOT_PASS=change_me_root_password

# Vectors Database
_APP_DB_HOST_VECTORSDB=mariadb
_APP_DB_PORT_VECTORSDB=3306
_APP_DB_SCHEMA_VECTORSDB=appwrite_vectors
_APP_DB_USER_VECTORSDB=appwrite
_APP_DB_PASS_VECTORSDB=change_me_db_password

# Redis
_APP_REDIS_HOST=redis
_APP_REDIS_PORT=6379

# Encryption
_APP_OPENSSL_KEY_BASE=change_me_generate_random_64_chars

# Storage
_APP_STORAGE_DEVICE=local
_APP_STORAGE_S3_ENDPOINT=
_APP_STORING_S3_ENDPOINT=
_APP_STORAGE_S3_BUCKET=
_APP_STORAGE_S3_ACCESS_KEY=
_APP_STORAGE_S3_SECRET_KEY=
_APP_STORAGE_S3_REGION=

# SMTP
_APP_SMTP_HOST=
_APP_SMTP_PORT=587
_APP_SMTP_SECURE=true
_APP_SMTP_USERNAME=
_APP_SMTP_PASSWORD=

# SMS
_APP_SMS_PROVIDER=

# Console
_APP_CONSOLE_WHITELIST_ROOT=0
_APP_CONSOLE_WHITELIST_EMAILS=
_APP_SYSTEM_EMAIL_NAME=Appwrite
_APP_SYSTEM_EMAIL_ADDRESS=appwrite@yourdomain.com
_APP_SYSTEM_RESPONSE_FORMAT=
